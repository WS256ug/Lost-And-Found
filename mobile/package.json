{
  "name": "lostfound-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5173",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 127.0.0.1 --port 4173",
    "cap:sync": "node ./node_modules/@capacitor/cli/bin/capacitor sync",
    "cap:android": "node ./node_modules/@capacitor/cli/bin/capacitor open android"
  },
  "dependencies": {
    "@capacitor/android": "7.6.5",
    "@capacitor/core": "7.6.5",
    "@ionic/react": "8.8.8",
    "ionicons": "8.0.13",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "7.6.5",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "typescript": "5.9.3",
    "vite": "6.4.2"
  }
}
