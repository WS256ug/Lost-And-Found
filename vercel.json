{
  "builds": [
    {
      "src": "lostfound/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "lostfound/wsgi.py"
    }
  ],
  "buildCommand": "python manage.py collectstatic --noinput && python manage.py migrate --noinput"
}
